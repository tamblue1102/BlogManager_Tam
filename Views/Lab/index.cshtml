<h1>Thử nghiệm C# và LINQ</h1>
<p><strong>Tổng số lượt xem tất cả bài viết:</strong> @ViewBag.TongLuotXem lượt</p>

<!--Bài viết nhiều lượt xem nhất -->
@if (ViewBag.BaiVietHot != null)
{
    <p>
        <strong>Bài viết có nhiều lượt xem nhất:</strong> 
        @ViewBag.BaiVietHot.Title - Tác giả: @ViewBag.BaiVietHot.Author (@ViewBag.BaiVietHot.ViewCount lượt xem)
    </p>
}

<hr />

<!--Danh sách bài đã xuất bản (Sắp xếp ViewCount giảm dần) -->
<h3>Danh sách bài viết đã xuất bản (Xem nhiều nhất -> ít nhất)</h3>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tiêu đề</th>
            <th>Tác giả</th>
            <th>Lượt xem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in ViewBag.BaiVietDaXuatBan)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    @item.Title 
                    <!-- Hiển thị nhãn Phổ biến / Thường bên cạnh Tiêu đề -->
                    <span class="badge @(item.ViewCount >= 100 ? "bg-success" : "bg-secondary") ms-2">
                        @item.GetNhanPhobien()
                    </span>
                </td>
                <td>@item.Title</td>
                <td>@item.Author</td>
                <td>@item.ViewCount</td>
            </tr>
        }
    </tbody>
</table>